<#
.SYNOPSIS
    Get-AzPaaSAvailability - Scan Azure PaaS compute service availability across regions.

.DESCRIPTION
    Scans Azure regions for PaaS service availability, capacity, quota, and pricing.
    Currently supports:
    - Azure SQL Database: SKU/tier discovery, vCore quota, zone redundancy, license types
    - Azure SQL Managed Instance: Family/vCore options, storage, instance pool support
    - Azure Cosmos DB: Subscription-level region access control, AZ support, residency

    Provides a comprehensive view of:
    - Available SKUs/tiers per region with status (Available/Disabled/Visible)
    - Subscription quota usage (vCores, server count) — surfaces deployment blockers
    - Zone redundancy and storage redundancy options
    - Cosmos DB subscription access flags — reveals hidden allowlisting requirements
    - Retail pricing (opt-in via -FetchPricing)
    - CSV/XLSX export

    Companion tool to:
    - Get-AzVMAvailability  — VM SKU capacity scanning
    - Get-AzAIModelAvailability — AI model availability scanning

.PARAMETER SubscriptionId
    One or more Azure subscription IDs to scan. If not provided, uses current Az context.

.PARAMETER Region
    One or more Azure region codes to scan (e.g., 'eastus', 'westus2').
    If not provided, prompts interactively or uses defaults with -NoPrompt.

.PARAMETER RegionPreset
    Predefined region set for common scenarios.
    Sovereign cloud presets (USGov, China) auto-set the environment.

.PARAMETER Service
    Which PaaS service(s) to scan: SqlDatabase, CosmosDB, or All (default).

.PARAMETER Edition
    Filter SQL Database editions: GeneralPurpose, BusinessCritical, Hyperscale.

.PARAMETER ComputeModel
    Filter SQL Database compute model: Provisioned or Serverless.

.PARAMETER SqlResourceType
    SQL resource type to scan: SqlDatabase (default), ManagedInstance, or ElasticPool.

.PARAMETER IncludeDisabled
    Include Disabled and Visible SKUs in output (hidden by default).

.PARAMETER FetchPricing
    Include retail pricing data from Azure Retail Prices API.

.PARAMETER ExportPath
    Directory path for CSV/XLSX export.

.PARAMETER AutoExport
    Automatically export results without prompting.

.PARAMETER NoPrompt
    Skip all interactive prompts. Uses defaults or provided parameters.

.PARAMETER OutputFormat
    Export format: 'Auto' (detects XLSX capability), 'CSV', or 'XLSX'.

.PARAMETER UseAsciiIcons
    Force ASCII icons instead of Unicode.

.PARAMETER Environment
    Azure cloud environment override. Auto-detects from Az context if not specified.

.PARAMETER MaxRetries
    Max retry attempts for transient API errors (429, 503, timeouts). Default: 3.

.PARAMETER JsonOutput
    Emit results as JSON to stdout instead of formatted Write-Host output.

.NOTES
    Name:           Get-AzPaaSAvailability
    Author:         Zachary Luz
    Created:        2026-03-25
    Version:        0.1.0
    License:        MIT

    Requirements:   Az.Accounts module
                    PowerShell 7+ (recommended)

    See also:       Get-AzVMAvailability — VM SKU capacity scanning
                    Get-AzAIModelAvailability — AI model availability scanning

.EXAMPLE
    .\Get-AzPaaSAvailability.ps1
    Run interactively — prompts for region selection, scans SQL + Cosmos DB.

.EXAMPLE
    .\Get-AzPaaSAvailability.ps1 -Region "eastus","westus2" -NoPrompt
    Scan two regions for all PaaS services without prompts.

.EXAMPLE
    .\Get-AzPaaSAvailability.ps1 -Service SqlDatabase -Edition Hyperscale -RegionPreset USMajor -NoPrompt
    Check Hyperscale SQL availability across major US regions.

.EXAMPLE
    .\Get-AzPaaSAvailability.ps1 -Service CosmosDB -RegionPreset Global -NoPrompt
    Check Cosmos DB subscription access across global regions.

.EXAMPLE
    .\Get-AzPaaSAvailability.ps1 -Service SqlDatabase -SqlResourceType ManagedInstance -Region eastus -NoPrompt
    Check SQL Managed Instance SKU availability in East US.

.EXAMPLE
    .\Get-AzPaaSAvailability.ps1 -FetchPricing -AutoExport -NoPrompt
    Scan all services with pricing and auto-export to XLSX.

.LINK
    https://github.com/zacharyluz/Get-AzPaaSAvailability
#>

[CmdletBinding()]
param(
    [Parameter(Mandatory = $false, HelpMessage = "Azure subscription ID(s) to scan")]
    [Alias("SubId", "Subscription")]
    [string[]]$SubscriptionId,

    [Parameter(Mandatory = $false, HelpMessage = "Azure region(s) to scan")]
    [Alias("Location")]
    [string[]]$Region,

    [Parameter(Mandatory = $false, HelpMessage = "Predefined region sets")]
    [ValidateSet("USEastWest", "USCentral", "USMajor", "Europe", "AsiaPacific", "Global", "USGov", "China", "ASR-EastWest", "ASR-CentralUS")]
    [string]$RegionPreset,

    [Parameter(Mandatory = $false, HelpMessage = "PaaS service(s) to scan")]
    [ValidateSet("SqlDatabase", "CosmosDB", "All")]
    [string]$Service = "All",

    [Parameter(Mandatory = $false, HelpMessage = "Filter SQL editions")]
    [ValidateSet("GeneralPurpose", "BusinessCritical", "Hyperscale")]
    [string[]]$Edition,

    [Parameter(Mandatory = $false, HelpMessage = "Filter SQL compute model")]
    [ValidateSet("Provisioned", "Serverless")]
    [string]$ComputeModel,

    [Parameter(Mandatory = $false, HelpMessage = "SQL resource type to scan")]
    [ValidateSet("SqlDatabase", "ManagedInstance", "ElasticPool")]
    [string]$SqlResourceType = "SqlDatabase",

    [Parameter(Mandatory = $false, HelpMessage = "Include Disabled/Visible SKUs")]
    [switch]$IncludeDisabled,

    [Parameter(Mandatory = $false, HelpMessage = "Include retail pricing")]
    [switch]$FetchPricing,

    [Parameter(Mandatory = $false, HelpMessage = "Directory path for export")]
    [string]$ExportPath,

    [Parameter(Mandatory = $false, HelpMessage = "Auto-export results")]
    [switch]$AutoExport,

    [Parameter(Mandatory = $false, HelpMessage = "Skip all interactive prompts")]
    [switch]$NoPrompt,

    [Parameter(Mandatory = $false, HelpMessage = "Export format: Auto, CSV, or XLSX")]
    [ValidateSet("Auto", "CSV", "XLSX")]
    [string]$OutputFormat = "Auto",

    [Parameter(Mandatory = $false, HelpMessage = "Force ASCII icons")]
    [switch]$UseAsciiIcons,

    [Parameter(Mandatory = $false, HelpMessage = "Azure cloud environment")]
    [ValidateSet("AzureCloud", "AzureUSGovernment", "AzureChinaCloud", "AzureGermanCloud")]
    [string]$Environment,

    [Parameter(Mandatory = $false, HelpMessage = "Max retry attempts")]
    [ValidateRange(0, 10)]
    [int]$MaxRetries = 3,

    [Parameter(Mandatory = $false, HelpMessage = "Emit JSON output")]
    [switch]$JsonOutput
)

$ErrorActionPreference = 'Continue'
$ProgressPreference = 'SilentlyContinue'

# Normalize string[] params — pwsh -File passes comma-delimited values as a single string
foreach ($paramName in @('SubscriptionId', 'Region', 'Edition')) {
    $val = Get-Variable -Name $paramName -ValueOnly -ErrorAction SilentlyContinue
    if ($val -and $val.Count -eq 1 -and $val[0] -match ',') {
        Set-Variable -Name $paramName -Value @($val[0] -split ',' | ForEach-Object { $_.Trim().Trim('"', "'") } | Where-Object { $_ })
    }
}

#region Configuration
$ScriptVersion = "0.1.0"

#region Constants
$OutputWidth = 113
$HoursPerMonth = 730
$DefaultRegions = @('eastus', 'eastus2', 'westus2')
$MaxRegions = 10
$SqlApiVersion = '2021-11-01'
$CosmosDbApiVersion = '2025-10-15'
#endregion Constants

$Regions = $Region

$RegionPresets = @{
    'USEastWest'    = @('eastus', 'eastus2', 'westus', 'westus2')
    'USCentral'     = @('centralus', 'northcentralus', 'southcentralus', 'westcentralus')
    'USMajor'       = @('eastus', 'eastus2', 'centralus', 'westus', 'westus2')
    'Europe'        = @('westeurope', 'northeurope', 'uksouth', 'francecentral', 'germanywestcentral')
    'AsiaPacific'   = @('eastasia', 'southeastasia', 'japaneast', 'australiaeast', 'koreacentral')
    'Global'        = @('eastus', 'westeurope', 'southeastasia', 'australiaeast', 'brazilsouth')
    'USGov'         = @('usgovvirginia', 'usgovtexas', 'usgovarizona')
    'China'         = @('chinaeast', 'chinanorth', 'chinaeast2', 'chinanorth2')
    'ASR-EastWest'  = @('eastus', 'westus2')
    'ASR-CentralUS' = @('centralus', 'eastus2')
}

if ($RegionPreset) {
    $Regions = $RegionPresets[$RegionPreset]
    Write-Verbose "Using region preset '$RegionPreset': $($Regions -join ', ')"

    if ($RegionPreset -eq 'USGov' -and -not $Environment) {
        $script:TargetEnvironment = 'AzureUSGovernment'
        Write-Verbose "Auto-setting environment to AzureUSGovernment for USGov preset"
    }
    elseif ($RegionPreset -eq 'China' -and -not $Environment) {
        $script:TargetEnvironment = 'AzureChinaCloud'
        Write-Verbose "Auto-setting environment to AzureChinaCloud for China preset"
    }
}

if ($Environment) {
    $script:TargetEnvironment = $Environment
}

# Detect execution environment
$isCloudShell = $env:CLOUD_SHELL -eq "true" -or (Test-Path "/home/system" -ErrorAction SilentlyContinue)
$defaultExportPath = if ($isCloudShell) { "/home/system" } else { "C:\Temp\AzPaaSAvailability" }

# Auto-detect Unicode support
$supportsUnicode = -not $UseAsciiIcons -and (
    $Host.UI.SupportsVirtualTerminal -or
    $env:WT_SESSION -or
    $env:TERM_PROGRAM -eq 'vscode' -or
    ($env:TERM -and $env:TERM -match 'xterm|256color')
)

$Icons = if ($supportsUnicode) {
    @{ Check = '✓'; Warning = '⚠'; Error = '✗' }
}
else {
    @{ Check = '[+]'; Warning = '[!]'; Error = '[-]' }
}

if ($AutoExport -and -not $ExportPath) {
    $ExportPath = $defaultExportPath
}

