function Get-PaaSPricing {
    <#
    .SYNOPSIS
        Fetches retail pricing for a PaaS service from Azure Retail Prices API.
    #>
    param(
        [Parameter(Mandatory)][string]$ServiceName,
        [Parameter(Mandatory)][string]$Region,
        [string]$PricingApiUrl = 'https://prices.azure.com/api/retail/prices',
        [int]$MaxRetries = 3,
        [int]$MaxPages = 10
    )

    $armLocation = $Region.ToLower() -replace '\s', ''
    $filter = "armRegionName eq '$armLocation' and priceType eq 'Consumption' and serviceName eq '$ServiceName'"
    $apiUrl = "$PricingApiUrl`?`$filter=$([uri]::EscapeDataString($filter))"

    $prices = @{}
    $nextLink = $apiUrl
    $pageCount = 0

    try {
        while ($nextLink -and $pageCount -lt $MaxPages) {
            $uri = $nextLink
            $response = Invoke-WithRetry -MaxRetries $MaxRetries -OperationName "Pricing API ($ServiceName, page $($pageCount + 1))" -ScriptBlock {
                Invoke-RestMethod -Uri $uri -Method Get -TimeoutSec 30
            }
            $pageCount++

            foreach ($item in $response.Items) {
                # Skip Windows-specific and low priority
                if ($item.productName -match 'Windows' -or $item.skuName -match 'Low Priority') { continue }

                $key = "$($item.armSkuName)-$($item.skuName)"
                if (-not $prices.ContainsKey($key) -or $item.type -eq 'Consumption') {
                    $prices[$key] = @{
                        SkuName      = $item.armSkuName
                        MeterName    = $item.meterName
                        UnitPrice    = $item.unitPrice
                        UnitOfMeasure = $item.unitOfMeasure
                        ProductName  = $item.productName
                    }
                }
            }

            $nextLink = $response.NextPageLink
        }
    }
    catch {
        Write-Verbose "Failed to get pricing for $ServiceName in $Region`: $($_.Exception.Message)"
    }

    return $prices
}

#endregion Pricing Functions
#region Initialize Azure Endpoints

$script:AzureEndpoints = Get-AzureEndpoints -EnvironmentName $script:TargetEnvironment

#endregion Initialize Azure Endpoints
#region Interactive Prompts

if (-not $SubscriptionId -or $SubscriptionId.Count -eq 0) {
    $ctx = Get-AzContext -ErrorAction SilentlyContinue
    if ($ctx -and $ctx.Subscription.Id) {
        $SubscriptionId = @($ctx.Subscription.Id)
        Write-Host "Using current subscription: $($ctx.Subscription.Name)" -ForegroundColor DarkGray
    }
    else {
        Write-Host "ERROR: No Azure context found. Run Connect-AzAccount first." -ForegroundColor Red
        return
    }
}

if (-not $Regions) {
    if ($NoPrompt) {
        $Regions = $DefaultRegions
        Write-Host "Using default regions: $($Regions -join ', ')" -ForegroundColor DarkGray
    }
    else {
        Write-Host "`nAvailable region presets:" -ForegroundColor Yellow
        $presetNames = @($RegionPresets.Keys | Sort-Object)
        for ($i = 0; $i -lt $presetNames.Count; $i++) {
            $pName = $presetNames[$i]
            Write-Host "  $($i + 1). $pName ($($RegionPresets[$pName] -join ', '))" -ForegroundColor White
        }
        Write-Host "`nSelect preset (1-$($presetNames.Count)), or type region codes (comma-separated): " -ForegroundColor Yellow -NoNewline
        $regionInput = Read-Host

        if ($regionInput -match '^\d+$' -and [int]$regionInput -ge 1 -and [int]$regionInput -le $presetNames.Count) {
            $selectedPreset = $presetNames[[int]$regionInput - 1]
            $Regions = $RegionPresets[$selectedPreset]
            Write-Host "Using preset '$selectedPreset': $($Regions -join ', ')" -ForegroundColor Green
        }
        elseif (-not [string]::IsNullOrWhiteSpace($regionInput)) {
            $Regions = @($regionInput -split ',' | ForEach-Object { $_.Trim().ToLower() } | Where-Object { $_ })
        }
        else {
            $Regions = $DefaultRegions
            Write-Host "Using default regions: $($Regions -join ', ')" -ForegroundColor DarkGray
        }
    }
}

if ($Regions.Count -gt $MaxRegions) {
    Write-Warning "Maximum $MaxRegions regions supported. Truncating to first $MaxRegions."
    $Regions = $Regions | Select-Object -First $MaxRegions
}

$scanSql = $Service -in @('SqlDatabase', 'All')
$scanCosmos = $Service -in @('CosmosDB', 'All')

#endregion Interactive Prompts
#region Banner

Write-Host "`n" -NoNewline
Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
Write-Host "GET-AZPAASAVAILABILITY v$ScriptVersion" -ForegroundColor Magenta
Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
Write-Host "Subscription(s): $($SubscriptionId -join ', ')" -ForegroundColor Cyan
Write-Host "Regions: $($Regions -join ', ')" -ForegroundColor Cyan

$serviceList = @()
if ($scanSql) { $serviceList += "SQL Database ($SqlResourceType)" }
if ($scanCosmos) { $serviceList += "Cosmos DB" }
Write-Host "Services: $($serviceList -join ', ')" -ForegroundColor Cyan

$filterInfo = @()
if ($Edition) { $filterInfo += "Editions: $($Edition -join ', ')" }
if ($ComputeModel) { $filterInfo += "Compute: $ComputeModel" }
if ($FetchPricing) { $filterInfo += "Pricing: ON" }
if ($filterInfo.Count -gt 0) {
    Write-Host ($filterInfo -join ' | ') -ForegroundColor Yellow
}
Write-Host "Icons: $(if ($supportsUnicode) { 'Unicode' } else { 'ASCII' }) | Cloud: $($script:AzureEndpoints.EnvironmentName)" -ForegroundColor DarkGray
Write-Host ("=" * $OutputWidth) -ForegroundColor Gray

#endregion Banner
#region Data Collection

$scanStart = Get-Date
$allSqlData = @{}
$allCosmosData = @()
$allSqlUsages = @{}
$allPricing = @{}

# Get access token
$armUrl = $script:AzureEndpoints.ResourceManagerUrl
$tokenObj = Get-AzAccessToken -ResourceUrl $armUrl -AsSecureString
$accessToken = [System.Net.NetworkCredential]::new('', $tokenObj.Token).Password

foreach ($subId in $SubscriptionId) {
    if ($SubscriptionId.Count -gt 1) {
        try {
            $subObj = Set-AzContext -SubscriptionId $subId -ErrorAction Stop
            $subName = $subObj.Subscription.Name
        }
        catch {
            Write-Host "  $($Icons.Error) Failed to switch to subscription $subId`: $($_.Exception.Message)" -ForegroundColor Red
            continue
        }
        Write-Host "`nScanning subscription: $subName ($subId)" -ForegroundColor Yellow
        $tokenObj = Get-AzAccessToken -ResourceUrl $armUrl -AsSecureString
        $accessToken = [System.Net.NetworkCredential]::new('', $tokenObj.Token).Password
    }

    #region SQL Data Collection
    if ($scanSql) {
        Write-Host "Scanning SQL $SqlResourceType in $($Regions.Count) region(s)..." -ForegroundColor Yellow

        foreach ($regionCode in $Regions) {
            try {
                $sqlSkus = Get-SqlCapabilities `
                    -Region $regionCode `
                    -SubscriptionId $subId `
                    -AccessToken $accessToken `
                    -ArmUrl $armUrl `
                    -ApiVersion $SqlApiVersion `
                    -ResourceType $SqlResourceType `
                    -EditionFilter $Edition `
                    -ComputeModelFilter $ComputeModel `
                    -IncludeDisabledSkus:$IncludeDisabled `
                    -MaxRetries $MaxRetries

                $usages = Get-SqlSubscriptionUsages `
                    -Region $regionCode `
                    -SubscriptionId $subId `
                    -AccessToken $accessToken `
                    -ArmUrl $armUrl `
                    -ApiVersion $SqlApiVersion `
                    -MaxRetries $MaxRetries

                $allSqlData[$regionCode] = $sqlSkus
                $allSqlUsages[$regionCode] = $usages

                if ($sqlSkus.Count -eq 0 -and -not $IncludeDisabled) {
                    # Check if there are Visible/Disabled SKUs the user isn't seeing
                    $allSkus = Get-SqlCapabilities `
                        -Region $regionCode `
                        -SubscriptionId $subId `
                        -AccessToken $accessToken `
                        -ArmUrl $armUrl `
                        -ApiVersion $SqlApiVersion `
                        -ResourceType $SqlResourceType `
                        -EditionFilter $Edition `
                        -ComputeModelFilter $ComputeModel `
                        -IncludeDisabledSkus `
                        -MaxRetries $MaxRetries
                    $visibleCount = @($allSkus | Where-Object { $_.Status -eq 'Visible' }).Count
                    $disabledCount = @($allSkus | Where-Object { $_.Status -eq 'Disabled' }).Count
                    $hiddenCount = $allSkus.Count
                    $allSqlData["${regionCode}_hidden"] = $hiddenCount
                    $allSqlData["${regionCode}_visible"] = $visibleCount
                    $allSqlData["${regionCode}_disabled"] = $disabledCount
                    if ($hiddenCount -gt 0) {
                        $breakdown = @()
                        if ($visibleCount -gt 0) { $breakdown += "$visibleCount Visible" }
                        if ($disabledCount -gt 0) { $breakdown += "$disabledCount Disabled" }
                        Write-Host "  $($Icons.Warning) $regionCode`: 0 available SKUs ($($breakdown -join ', ') — use -IncludeDisabled)" -ForegroundColor Yellow
                    }
                    else {
                        Write-Host "  $($Icons.Check) $regionCode`: 0 SKUs" -ForegroundColor DarkGray
                    }
                }
                else {
                    Write-Host "  $($Icons.Check) $regionCode`: $($sqlSkus.Count) SKUs" -ForegroundColor Green
                }
            }
            catch {
                Write-Host "  $($Icons.Error) $regionCode`: $($_.Exception.Message)" -ForegroundColor Red
                $allSqlData[$regionCode] = @()
                $allSqlUsages[$regionCode] = @{}
            }
        }

        # Fetch pricing if requested
        if ($FetchPricing) {
            Write-Host "Fetching SQL pricing..." -ForegroundColor Yellow
            foreach ($regionCode in $Regions) {
                try {
                    $pricing = Get-PaaSPricing `
                        -ServiceName 'SQL Database' `
                        -Region $regionCode `
                        -PricingApiUrl $script:AzureEndpoints.PricingApiUrl `
                        -MaxRetries $MaxRetries
                    $allPricing["sql-$regionCode"] = $pricing
                    Write-Host "  $($Icons.Check) $regionCode`: $($pricing.Count) price entries" -ForegroundColor Green
                }
                catch {
                    Write-Verbose "Pricing fetch failed for $regionCode`: $($_.Exception.Message)"
                }
            }
        }
    }
    #endregion SQL Data Collection

    #region Cosmos DB Data Collection
    if ($scanCosmos) {
        Write-Host "Scanning Cosmos DB region access..." -ForegroundColor Yellow

        try {
            $cosmosLocations = Get-CosmosDbLocations `
                -SubscriptionId $subId `
                -AccessToken $accessToken `
                -ArmUrl $armUrl `
                -ApiVersion $CosmosDbApiVersion `
                -RegionFilter $Regions `
                -MaxRetries $MaxRetries

            $allCosmosData = $cosmosLocations
            $blockedCount = @($cosmosLocations | Where-Object { $_.ActionRequired -ne 'None' }).Count
            Write-Host "  $($Icons.Check) $($cosmosLocations.Count) regions checked ($blockedCount blocked)" -ForegroundColor $(if ($blockedCount -gt 0) { 'Yellow' } else { 'Green' })
        }
        catch {
            Write-Host "  $($Icons.Error) Cosmos DB: $($_.Exception.Message)" -ForegroundColor Red
            $allCosmosData = @()
        }
    }
    #endregion Cosmos DB Data Collection
}

$scanElapsed = (Get-Date) - $scanStart
Write-Host "Scan complete in $([math]::Round($scanElapsed.TotalSeconds, 1))s" -ForegroundColor Green

#endregion Data Collection
#region Display SQL Results

if ($scanSql -and $allSqlData.Count -gt 0) {
    foreach ($regionCode in $Regions) {
        $skus = $allSqlData[$regionCode]
        $usages = $allSqlUsages[$regionCode]

        if (-not $skus -or $skus.Count -eq 0) {
            $hiddenCount = $allSqlData["${regionCode}_hidden"]
            if ($hiddenCount -and $hiddenCount -gt 0) {
                Write-Host ""
                Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
                Write-Host "SQL $($SqlResourceType.ToUpper()): $regionCode" -ForegroundColor Yellow
                Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
                $visibleCount = $allSqlData["${regionCode}_visible"]
                $disabledCount = $allSqlData["${regionCode}_disabled"]
                $breakdown = @()
                if ($visibleCount -gt 0) { $breakdown += "$visibleCount Visible" }
                if ($disabledCount -gt 0) { $breakdown += "$disabledCount Disabled" }
                Write-Host "No Available/Default SKUs. $($breakdown -join ' + ') = $hiddenCount total." -ForegroundColor Yellow
                Write-Host "" -NoNewline
                if ($visibleCount -gt 0) {
                    Write-Host "  Visible  = SKU exists but your subscription cannot provision it (may need allowlisting)" -ForegroundColor Yellow
                }
                if ($disabledCount -gt 0) {
                    Write-Host "  Disabled = SKU is explicitly disabled in this region" -ForegroundColor Red
                }
                Write-Host "Re-run with -IncludeDisabled to see all SKUs." -ForegroundColor DarkGray
            }
            continue
        }

        Write-Host ""
        Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
        Write-Host "SQL $($SqlResourceType.ToUpper()): $regionCode" -ForegroundColor Cyan
        Write-Host ("=" * $OutputWidth) -ForegroundColor Gray

        if ($SqlResourceType -eq 'SqlDatabase') {
            $headerFmt = "{0,-18} {1,-16} {2,6} {3,5} {4,-12} {5,-6} {6,-10} {7,-12} {8,-14}"
            Write-Host ($headerFmt -f "Edition", "SKU", "vCores", "Zone", "Compute", "AHUB", "Status", "Storage", "Quota(vCores)") -ForegroundColor White
            Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray

            $vCoreQuota = $usages['RegionalVCoreQuotaForSQLDBAndDW']
            $quotaDisplay = if ($vCoreQuota) { "$([int]$vCoreQuota.CurrentValue)/$([int]$vCoreQuota.Limit)" } else { '-' }

            foreach ($sku in ($skus | Sort-Object Edition, vCores)) {
                $zoneIcon = if ($sku.ZoneRedundant) { $Icons.Check } else { $Icons.Error }
                $ahubDisplay = if ($sku.AHUBSupported) { 'Yes' } else { 'No' }

                $statusColor = switch ($sku.Status) {
                    'Available' { 'Green' }
                    'Default'   { 'Green' }
                    'Visible'   { 'Yellow' }
                    'Disabled'  { 'Red' }
                    default     { 'Gray' }
                }

                $storageDisplay = if ($sku.StorageRedundancy.Length -gt 12) { $sku.StorageRedundancy.Substring(0, 9) + '...' } else { $sku.StorageRedundancy }
                $skuDisplay = if ($sku.SKU.Length -gt 16) { $sku.SKU.Substring(0, 13) + '...' } else { $sku.SKU }

                Write-Host ($headerFmt -f $sku.Edition, $skuDisplay, $sku.vCores, $zoneIcon, $sku.ComputeModel, $ahubDisplay, $sku.Status, $storageDisplay, $quotaDisplay) -ForegroundColor $statusColor
            }

            Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray

            # Status legend — show when mixed statuses or -IncludeDisabled
            $uniqueStatuses = @($skus | ForEach-Object { $_.Status } | Sort-Object -Unique)
            $hasNonAvailable = $uniqueStatuses | Where-Object { $_ -notin @('Available', 'Default') }
            if ($hasNonAvailable -or $IncludeDisabled) {
                Write-Host "STATUS KEY:" -ForegroundColor DarkGray -NoNewline
                Write-Host " Available" -ForegroundColor Green -NoNewline
                Write-Host " = provisionable |" -ForegroundColor DarkGray -NoNewline
                Write-Host " Default" -ForegroundColor Green -NoNewline
                Write-Host " = provisionable (default) |" -ForegroundColor DarkGray -NoNewline
                Write-Host " Visible" -ForegroundColor Yellow -NoNewline
                Write-Host " = exists, sub can't provision |" -ForegroundColor DarkGray -NoNewline
                Write-Host " Disabled" -ForegroundColor Red -NoNewline
                Write-Host " = explicitly disabled" -ForegroundColor DarkGray
            }

            # Quota summary
            $serverQuota = $usages['ServerQuota']
            if ($serverQuota) {
                Write-Host "Server Quota: $([int]$serverQuota.CurrentValue)/$([int]$serverQuota.Limit)" -ForegroundColor DarkGray -NoNewline
                Write-Host " | " -ForegroundColor DarkGray -NoNewline
            }
            if ($vCoreQuota) {
                $pct = if ($vCoreQuota.Limit -gt 0) { [math]::Round(($vCoreQuota.CurrentValue / $vCoreQuota.Limit) * 100, 0) } else { 0 }
                $quotaColor = if ($pct -ge 80) { 'Red' } elseif ($pct -ge 50) { 'Yellow' } else { 'Green' }
                Write-Host "vCore Quota: $([int]$vCoreQuota.CurrentValue)/$([int]$vCoreQuota.Limit) ($pct%)" -ForegroundColor $quotaColor
            }
            else {
                Write-Host "vCore Quota: unavailable" -ForegroundColor DarkGray
            }
        }
        elseif ($SqlResourceType -eq 'ManagedInstance') {
            $headerFmt = "{0,-18} {1,-20} {2,6} {3,5} {4,-6} {5,-10} {6,-10} {7,-12}"
            Write-Host ($headerFmt -f "Edition", "SKU", "vCores", "Zone", "AHUB", "Pool", "Status", "Storage(GB)") -ForegroundColor White
            Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray

            foreach ($sku in ($skus | Sort-Object Edition, vCores)) {
                $zoneIcon = if ($sku.ZoneRedundant) { $Icons.Check } else { $Icons.Error }
                $ahubDisplay = if ($sku.AHUBSupported) { 'Yes' } else { 'No' }
                $poolDisplay = if ($sku.InstancePoolSupported) { 'Yes' } else { 'No' }

                $statusColor = switch ($sku.Status) {
                    'Available' { 'Green' }
                    'Default'   { 'Green' }
                    'Visible'   { 'Yellow' }
                    'Disabled'  { 'Red' }
                    default     { 'Gray' }
                }

                Write-Host ($headerFmt -f $sku.Edition, $sku.SKU, $sku.vCores, $zoneIcon, $ahubDisplay, $poolDisplay, $sku.Status, $sku.IncludedStorageGB) -ForegroundColor $statusColor
            }

            Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray
        }

        Write-Host "Total: $($skus.Count) SKUs" -ForegroundColor DarkGray
    }
}

#endregion Display SQL Results
#region Display Cosmos DB Results

if ($scanCosmos -and $allCosmosData.Count -gt 0) {
    Write-Host ""
    Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
    Write-Host "COSMOS DB REGION ACCESS" -ForegroundColor Cyan
    Write-Host ("=" * $OutputWidth) -ForegroundColor Gray

    $headerFmt = "{0,-18} {1,5} {2,-15} {3,-17} {4,-10} {5,-15} {6,-8}"
    Write-Host ($headerFmt -f "Region", "AZ", "Access (AZ)", "Access (Regular)", "Residency", "Backup", "Status") -ForegroundColor White
    Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray

    foreach ($loc in ($allCosmosData | Sort-Object Region)) {
        $azIcon = if ($loc.SupportsAZ) { $Icons.Check } else { $Icons.Error }

        $accessAzDisplay = if ($loc.SupportsAZ) {
            if ($loc.AccessAllowedAZ) { "$($Icons.Check) Allowed" } else { "$($Icons.Error) BLOCKED" }
        }
        else { '-' }

        $accessRegDisplay = if ($loc.AccessAllowedRegular) { "$($Icons.Check) Allowed" } else { "$($Icons.Error) BLOCKED" }
        $residencyDisplay = if ($loc.IsResidencyRestricted) { 'Yes' } else { 'No' }
        $backupDisplay = if ($loc.BackupRedundancies.Length -gt 15) { $loc.BackupRedundancies.Substring(0, 12) + '...' } else { $loc.BackupRedundancies }

        $rowColor = if ($loc.ActionRequired -ne 'None') { 'Red' }
        elseif (-not $loc.SupportsAZ) { 'Yellow' }
        else { 'Green' }

        Write-Host ($headerFmt -f $loc.Region, $azIcon, $accessAzDisplay, $accessRegDisplay, $residencyDisplay, $backupDisplay, $loc.Status) -ForegroundColor $rowColor
    }

    Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray

    # Action items
    $blockedRegions = @($allCosmosData | Where-Object { $_.ActionRequired -ne 'None' })
    if ($blockedRegions.Count -gt 0) {
        Write-Host ""
        Write-Host "$($Icons.Warning) ACTION REQUIRED:" -ForegroundColor Red
        foreach ($br in $blockedRegions) {
            Write-Host "  $($br.Region): $($br.ActionRequired)" -ForegroundColor Yellow
        }
    }
    else {
        Write-Host "All scanned regions are accessible." -ForegroundColor Green
    }
}

#endregion Display Cosmos DB Results
#region Cross-Service Summary

if ($scanSql -and $scanCosmos) {
    Write-Host ""
    Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
    Write-Host "CROSS-SERVICE REGION SUMMARY" -ForegroundColor Green
    Write-Host ("=" * $OutputWidth) -ForegroundColor Gray

    $summaryFmt = "{0,-18} {1,-20} {2,-20} {3,-25}"
    Write-Host ($summaryFmt -f "Region", "SQL SKUs", "Cosmos Access", "Notes") -ForegroundColor White
    Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray

    foreach ($regionCode in $Regions) {
        $sqlCount = if ($allSqlData[$regionCode]) { $allSqlData[$regionCode].Count } else { 0 }
        $hiddenCount = $allSqlData["${regionCode}_hidden"]
        $sqlDisplay = if ($sqlCount -gt 0) { "$($Icons.Check) $sqlCount SKUs" }
        elseif ($hiddenCount -and $hiddenCount -gt 0) { "$($Icons.Warning) $hiddenCount Visible" }
        else { "$($Icons.Error) No data" }

        $cosmosLoc = $allCosmosData | Where-Object { $_.Region -eq $regionCode }
        $cosmosDisplay = if ($cosmosLoc) {
            if ($cosmosLoc.AccessAllowedRegular) { "$($Icons.Check) Accessible" } else { "$($Icons.Error) BLOCKED" }
        }
        else { "$($Icons.Warning) Not checked" }

        $notes = @()
        $vCoreQuota = $allSqlUsages[$regionCode]['RegionalVCoreQuotaForSQLDBAndDW']
        if ($vCoreQuota -and $vCoreQuota.Limit -gt 0) {
            $pct = [math]::Round(($vCoreQuota.CurrentValue / $vCoreQuota.Limit) * 100, 0)
            if ($pct -ge 80) { $notes += "SQL quota ${pct}%" }
        }
        if ($cosmosLoc -and $cosmosLoc.ActionRequired -ne 'None') { $notes += 'Cosmos SR needed' }
        $notesDisplay = if ($notes.Count -gt 0) { $notes -join '; ' } else { '-' }

        $rowColor = if ($sqlCount -eq 0 -or ($cosmosLoc -and -not $cosmosLoc.AccessAllowedRegular)) { 'Red' }
        elseif ($notes.Count -gt 0) { 'Yellow' }
        else { 'Green' }

        Write-Host ($summaryFmt -f $regionCode, $sqlDisplay, $cosmosDisplay, $notesDisplay) -ForegroundColor $rowColor
    }

    Write-Host ("-" * $OutputWidth) -ForegroundColor DarkGray
}

#endregion Cross-Service Summary
#region Completion

$totalElapsed = (Get-Date) - $scanStart
$totalSqlSkus = ($allSqlData.Values | ForEach-Object { $_.Count } | Measure-Object -Sum).Sum
$totalCosmosRegions = $allCosmosData.Count

Write-Host ""
Write-Host ("=" * $OutputWidth) -ForegroundColor Gray
Write-Host "PAAS AVAILABILITY SCAN COMPLETE" -ForegroundColor Green
$statsLine = @()
if ($scanSql) { $statsLine += "SQL: $totalSqlSkus SKUs" }
if ($scanCosmos) { $statsLine += "Cosmos DB: $totalCosmosRegions regions" }
Write-Host "$($statsLine -join ' | ') | Regions: $($Regions.Count) | Time: $([math]::Round($totalElapsed.TotalSeconds, 1))s" -ForegroundColor DarkGray
Write-Host "Generated: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')" -ForegroundColor DarkGray
Write-Host ("=" * $OutputWidth) -ForegroundColor Gray

#endregion Completion
#region JSON Output

if ($JsonOutput) {
    $output = @{
        schemaVersion = '1.0'
        generatedAt   = (Get-Date -Format 'o')
        scanDuration  = [math]::Round($totalElapsed.TotalSeconds, 1)
        regions       = $Regions
    }
    if ($scanSql) {
        $output.sqlSkus = $allSqlData
        $output.sqlUsages = $allSqlUsages
    }
    if ($scanCosmos) {
        $output.cosmosDbLocations = $allCosmosData
    }
    $output | ConvertTo-Json -Depth 10
}

#endregion JSON Output
#region Export

if ($ExportPath) {
    $timestamp = Get-Date -Format 'yyyyMMdd-HHmmss'
    $useXLSX = ($OutputFormat -eq 'XLSX') -or ($OutputFormat -eq 'Auto' -and (Test-ImportExcelModule))

    Write-Host "`nEXPORTING..." -ForegroundColor Cyan

    if (-not (Test-Path $ExportPath)) {
        New-Item -ItemType Directory -Path $ExportPath -Force | Out-Null
    }

    # SQL export rows
    $sqlExportRows = @()
    if ($scanSql) {
        foreach ($regionCode in $Regions) {
            $usages = $allSqlUsages[$regionCode]
            $vCoreQuota = $usages['RegionalVCoreQuotaForSQLDBAndDW']
            $serverQuota = $usages['ServerQuota']

            foreach ($sku in $allSqlData[$regionCode]) {
                $sqlExportRows += [PSCustomObject]@{
                    Region            = $sku.Region
                    ResourceType      = $sku.ResourceType
                    Edition           = $sku.Edition
                    SKU               = $sku.SKU
                    Family            = $sku.Family
                    vCores            = $sku.vCores
                    ComputeModel      = $sku.ComputeModel
                    ZoneRedundant     = $sku.ZoneRedundant
                    AHUBSupported     = $sku.AHUBSupported
                    StorageRedundancy = $sku.StorageRedundancy
                    Status            = $sku.Status
                    ServerQuota_Used  = if ($serverQuota) { [int]$serverQuota.CurrentValue } else { $null }
                    ServerQuota_Limit = if ($serverQuota) { [int]$serverQuota.Limit } else { $null }
                    VCoreQuota_Used   = if ($vCoreQuota) { [int]$vCoreQuota.CurrentValue } else { $null }
                    VCoreQuota_Limit  = if ($vCoreQuota) { [int]$vCoreQuota.Limit } else { $null }
                }
            }
        }
    }

    # Cosmos DB export rows
    $cosmosExportRows = @()
    if ($scanCosmos) {
        foreach ($loc in $allCosmosData) {
            $cosmosExportRows += [PSCustomObject]@{
                Region                = $loc.Region
                DisplayName           = $loc.DisplayName
                SupportsAZ            = $loc.SupportsAZ
                SubscriptionAccessAZ  = $loc.AccessAllowedAZ
                SubscriptionAccessRegular = $loc.AccessAllowedRegular
                IsResidencyRestricted = $loc.IsResidencyRestricted
                BackupRedundancies    = $loc.BackupRedundancies
                Status                = $loc.Status
                ActionRequired        = $loc.ActionRequired
            }
        }
    }

    if ($useXLSX) {
        $xlsxFile = Join-Path $ExportPath "AzPaaSAvailability-$timestamp.xlsx"

        if ($sqlExportRows.Count -gt 0) {
            $sqlExportRows | Export-Excel -Path $xlsxFile -WorksheetName "SQL SKUs" -AutoSize -FreezeTopRow -AutoFilter
        }
        if ($cosmosExportRows.Count -gt 0) {
            $cosmosExportRows | Export-Excel -Path $xlsxFile -WorksheetName "Cosmos DB Access" -AutoSize -FreezeTopRow -AutoFilter -Append
        }

        Write-Host "  $($Icons.Check) Exported: $xlsxFile" -ForegroundColor Green
        Write-Host "    SQL: $($sqlExportRows.Count) rows | Cosmos DB: $($cosmosExportRows.Count) rows" -ForegroundColor DarkGray
    }
    else {
        if ($sqlExportRows.Count -gt 0) {
            $csvFile = Join-Path $ExportPath "AzPaaSAvailability-SQL-$timestamp.csv"
            $sqlExportRows | Export-Csv -Path $csvFile -NoTypeInformation
            Write-Host "  $($Icons.Check) SQL: $csvFile ($($sqlExportRows.Count) rows)" -ForegroundColor Green
        }
        if ($cosmosExportRows.Count -gt 0) {
            $csvFile = Join-Path $ExportPath "AzPaaSAvailability-CosmosDB-$timestamp.csv"
            $cosmosExportRows | Export-Csv -Path $csvFile -NoTypeInformation
            Write-Host "  $($Icons.Check) Cosmos DB: $csvFile ($($cosmosExportRows.Count) rows)" -ForegroundColor Green
        }
    }
}

#endregion Export
